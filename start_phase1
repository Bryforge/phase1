#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PHASE1_HOME="${PHASE1_HOME:-$ROOT_DIR}"
PHASE1_LOCAL_DIR="${PHASE1_LOCAL_DIR:-$PHASE1_HOME/.phase1}"
PHASE1_CONFIG_FILE="${PHASE1_CONFIG_FILE:-$PHASE1_LOCAL_DIR/config/phase1.env}"

PHASE1_THEME="${PHASE1_THEME:-cyber}"
PHASE1_COLOR_MODE="${PHASE1_COLOR_MODE:-auto}"
PHASE1_SAFE_MODE="${PHASE1_SAFE_MODE:-1}"
PHASE1_DEVICE_MODE="${PHASE1_DEVICE_MODE:-desktop}"
PHASE1_GINA_ENABLED="${PHASE1_GINA_ENABLED:-1}"
PHASE1_TERMINAL_TITLE="${PHASE1_TERMINAL_TITLE:-Phase1 Command Center}"

RUN_CONFIGURE=0
RUN_DOCTOR=0
RUN_BASE1=0
RUN_QUALITY=0
NO_BUILD=0
SHOW_HELP=0
PASS_ARGS=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --configure) RUN_CONFIGURE=1 ;;
        --doctor) RUN_DOCTOR=1 ;;
        --base1) RUN_BASE1=1 ;;
        --quality) RUN_QUALITY=1 ;;
        --no-build) NO_BUILD=1 ;;
        --gina) PASS_ARGS="$PASS_ARGS gina" ;;
        -h|--help) SHOW_HELP=1 ;;
        --) shift; PASS_ARGS="$PASS_ARGS $*"; break ;;
        *) PASS_ARGS="$PASS_ARGS $1" ;;
    esac
    shift
done

esc() { printf '\033'; }
color_enabled() {
    [ "${NO_COLOR:-}" = "" ] && [ "$PHASE1_COLOR_MODE" != "mono" ] && [ -t 1 ]
}
fg() { if color_enabled; then printf '%s[38;5;%sm' "$(esc)" "$1"; fi; }
bold() { if color_enabled; then printf '%s[1m' "$(esc)"; fi; }
reset() { if color_enabled; then printf '%s[0m' "$(esc)"; fi; }
phase1_version() {
    awk -F '"' '/^version =/ { print $2; exit }' "$PHASE1_HOME/Cargo.toml" 2>/dev/null || printf '4.2.5-dev'
}

print_help() {
    cat <<'EOF'
Phase1 launch command

Usage:
  ./start_phase1
  ./start_phase1 --configure
  ./start_phase1 --doctor
  ./start_phase1 --base1
  ./start_phase1 --quality
  ./start_phase1 --gina
  ./start_phase1 --no-build

Simple launch command:
  ./start_phase1

Notes:
  Run `sh scripts/configure-phase1.sh` once for full local configuration.
  If your checkout does not preserve executable bits, run `sh start_phase1` or `chmod +x start_phase1`.
EOF
}

phase1_splash() {
    VERSION=$(phase1_version)
    if color_enabled; then
        printf '%s]0;%s%s' "$(esc)" "$PHASE1_TERMINAL_TITLE" "$(printf '\007')"
    fi
    printf '\n'
    fg 51; bold; printf '╔══════════════════════════════════════════════════════════════╗\n'; reset
    fg 45; bold; printf '║'; reset; fg 201; bold; printf '                           PHASE1                            '; reset; fg 45; bold; printf '║\n'; reset
    fg 45; bold; printf '║'; reset; fg 196; bold; printf '                    こんにちは、ハッカー！                    '; reset; fg 45; bold; printf '║\n'; reset
    fg 45; bold; printf '║'; reset; fg 118; printf '          advanced operator console • developer edge          '; reset; fg 45; bold; printf '║\n'; reset
    fg 51; bold; printf '╚══════════════════════════════════════════════════════════════╝\n'; reset
    fg 81; printf 'launch command : '; reset; bold; printf './start_phase1\n'; reset
    fg 81; printf 'edge version   : '; reset; printf 'v%s\n' "$VERSION"
    fg 81; printf 'stable track   : '; reset; printf 'v4.0.0\n'
    fg 81; printf 'previous stable: '; reset; printf 'v3.10.9\n'
    fg 81; printf 'safe mode      : '; reset; printf '%s\n' "$PHASE1_SAFE_MODE"
    fg 81; printf 'theme          : '; reset; printf '%s\n' "$PHASE1_THEME"
    fg 81; printf 'gina           : '; reset; printf '%s\n' "enabled/offline"
    printf '\n'

    SPIN='|/-\\'
    IDX=0
    for STEP in \
        "preparing kernel interface" \
        "mounting virtual filesystems" \
        "checking trust boundary" \
        "arming developer console"
    do
        IDX=$((IDX + 1))
        MARK=$(printf '%s' "$SPIN" | cut -c "$IDX")
        [ -n "$MARK" ] || MARK='*'
        fg 118; printf ' %s ' "$MARK"; reset
        printf '%s\n' "$STEP"
        sleep 0.10 2>/dev/null || sleep 1
    done
    fg 118; printf ' ✓ '; reset; printf 'all sub-systems nominal\n\n'
}

load_config() {
    if [ -f "$PHASE1_CONFIG_FILE" ]; then
        # shellcheck disable=SC1090
        . "$PHASE1_CONFIG_FILE"
    fi
}

phase1_doctor() {
    echo "Phase1 launch doctor"
    echo "home       : $PHASE1_HOME"
    echo "config     : $PHASE1_CONFIG_FILE"
    echo "local dir  : $PHASE1_LOCAL_DIR"
    echo "theme      : $PHASE1_THEME"
    echo "safe mode  : $PHASE1_SAFE_MODE"
    echo "device     : $PHASE1_DEVICE_MODE"
    echo "gina       : $PHASE1_GINA_ENABLED"
    if [ -f "$PHASE1_HOME/plugins/gina.wasi" ]; then echo "gina file  : present"; else echo "gina file  : missing"; fi
    if [ -f "$PHASE1_HOME/scripts/base1-preflight.sh" ]; then echo "base1      : preflight available"; else echo "base1      : preflight missing"; fi
    if command -v cargo >/dev/null 2>&1; then echo "cargo      : $(command -v cargo)"; else echo "cargo      : missing"; fi
    if [ -x "$PHASE1_HOME/target/release/phase1" ]; then echo "binary     : target/release/phase1"; elif [ -x "$PHASE1_HOME/target/debug/phase1" ]; then echo "binary     : target/debug/phase1"; else echo "binary     : will use cargo run when available"; fi
}

run_configure() {
    sh "$PHASE1_HOME/scripts/configure-phase1.sh"
}

run_base1() {
    if [ -f "$PHASE1_HOME/scripts/base1-preflight.sh" ]; then
        sh "$PHASE1_HOME/scripts/base1-preflight.sh"
    else
        echo "Base1 preflight script not found."
    fi
}

run_quality() {
    if [ -f "$PHASE1_HOME/scripts/quality-check.sh" ]; then
        sh "$PHASE1_HOME/scripts/quality-check.sh" files
        sh "$PHASE1_HOME/scripts/quality-check.sh" scripts
        sh "$PHASE1_HOME/scripts/quality-check.sh" score
    elif [ -f "$PHASE1_HOME/scripts/quality-score.sh" ]; then
        sh "$PHASE1_HOME/scripts/quality-score.sh"
    else
        echo "Quality scripts not found."
    fi
}

launch_phase1() {
    export PHASE1_HOME PHASE1_THEME PHASE1_COLOR_MODE PHASE1_SAFE_MODE PHASE1_DEVICE_MODE
    export PHASE1_GINA_ENABLED PHASE1_TERMINAL_TITLE
    export PHASE1_AI_MODE="offline"
    export PHASE1_LAUNCH_COMMAND="./start_phase1"

    cd "$PHASE1_HOME"

    if [ -x target/release/phase1 ]; then
        exec target/release/phase1 $PASS_ARGS
    fi
    if [ -x target/debug/phase1 ]; then
        exec target/debug/phase1 $PASS_ARGS
    fi
    if [ "$NO_BUILD" = "1" ]; then
        echo "No built Phase1 binary found and --no-build was set."
        exit 1
    fi
    if command -v cargo >/dev/null 2>&1; then
        exec cargo run -- $PASS_ARGS
    fi
    echo "Unable to launch Phase1: no binary found and Cargo is unavailable."
    exit 1
}

load_config

if [ "$SHOW_HELP" = "1" ]; then
    print_help
    exit 0
fi

if [ "$RUN_CONFIGURE" = "1" ]; then
    run_configure
fi

if [ "$RUN_DOCTOR" = "1" ]; then
    phase1_doctor
    exit 0
fi

phase1_splash

if [ "$RUN_BASE1" = "1" ]; then
    run_base1
fi

if [ "$RUN_QUALITY" = "1" ]; then
    run_quality
fi

launch_phase1
