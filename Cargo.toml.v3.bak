[package]
name = "phase1"
version = "3.0.0"
edition = "2021"
authors = ["Chase Bryan"]
description = "Terminal-based educational OS simulator in Rust. Demonstrates process management, memory accounting, kernel concepts, extensibility, dynamic spawning, disk simulation, editors, C compilation, networking, and terminal web browsing under Codename Blue."
license = "GPL-3.0"
readme = "README.md"

[profile.release]
opt-level = 3
lto = true
codegen-units = 1
panic = "abort"
strip = true

[dependencies]
chrono = "0.4.44"
